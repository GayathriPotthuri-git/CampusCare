# CampusCare Environment Variables
# Copy this file, rename it to .env and fill in your actual values

# Fast2SMS (get from fast2sms.com)
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# Twilio (get from twilio.com) - optional
TWILIO_SID=your_twilio_sid_here
TWILIO_TOKEN=your_twilio_token_here
TWILIO_FROM=your_twilio_number_here

# Server
PORT=3000
